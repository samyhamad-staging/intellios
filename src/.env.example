# ─── Required ────────────────────────────────────────────────────────────────

# Database (PostgreSQL)
# Local install:  postgresql://user:password@localhost:5432/intellios
# Docker Compose: postgresql://intellios:intellios@localhost:5432/intellios
DATABASE_URL=postgresql://intellios:intellios@localhost:5432/intellios

# Anthropic API — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# NextAuth session encryption — generate with: openssl rand -base64 32
# Docker Compose sets this automatically; only needed for non-Docker local dev.
AUTH_SECRET=

# ─── AWS / AgentCore (required for direct deploy to Amazon Bedrock) ───────────
# These are read by the AWS SDK from the environment.
# In production, prefer an IAM role attached to the compute (ECS task role,
# EC2 instance profile) instead of static keys — no key rotation needed.

AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_DEFAULT_REGION=us-east-1

# ─── Optional — Email Notifications ──────────────────────────────────────────
# Omit to disable email delivery (notifications will be silently skipped).
# Resend API key — https://resend.com
RESEND_API_KEY=re_...
# From address shown on notification emails (must be verified in Resend)
NOTIFICATION_FROM_EMAIL=notifications@yourdomain.com
# Base URL used to build deep-links in email bodies
NOTIFICATION_APP_URL=https://app.yourdomain.com

# ─── Cron security (required in production) ──────────────────────────────────
# Vercel cron routes are called with this secret in the Authorization header.
# REQUIRED in production — the app will refuse to start without it.
# Generate with: openssl rand -hex 32
CRON_SECRET=

# ─── Optional — SLA thresholds ───────────────────────────────────────────────
# Override enterprise policy defaults (hours)
SLA_REVIEW_WARN_HOURS=48
SLA_REVIEW_ALERT_HOURS=72

# ─── Optional — Redis ────────────────────────────────────────────────────────
# Connection URL for distributed rate limiting (recommended in multi-instance deployments).
# Without this the app falls back to in-process rate limiting (fine for single-instance dev).
# Docker Compose: redis://localhost:6379
# REDIS_URL=redis://localhost:6379

# ─── Optional — Logging ──────────────────────────────────────────────────────
# Minimum log level emitted by src/lib/logger.ts (default: "info")
# debug | info | warn | error
# LOG_LEVEL=info

# ─── Optional — AI model overrides ──────────────────────────────────────────
# Override the Claude model used for each task tier without code changes.
# Useful for responding to model deprecations or testing newer models.
# Defaults are the production-validated versions hardcoded in src/lib/ai/config.ts.
# AI_MODEL_SONNET=claude-sonnet-4-20250514
# AI_MODEL_HAIKU=claude-haiku-4-5-20251001

# ─── Demo mode ───────────────────────────────────────────────────────────────
# Set to "true" to show demo account quick-fill buttons on the login page.
# Omit or set to "false" in production (P1-56).
# NEXT_PUBLIC_DEMO_MODE=true
