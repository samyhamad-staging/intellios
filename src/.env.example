# ─── Required ────────────────────────────────────────────────────────────────

# Database (PostgreSQL)
# Local install:  postgresql://user:password@localhost:5432/intellios
# Docker Compose: postgresql://intellios:intellios@localhost:5432/intellios
DATABASE_URL=postgresql://intellios:intellios@localhost:5432/intellios

# Anthropic API — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# NextAuth session encryption — generate with: openssl rand -base64 32
# Docker Compose sets this automatically; only needed for non-Docker local dev.
AUTH_SECRET=

# ─── AWS / AgentCore (required for direct deploy to Amazon Bedrock) ───────────
# These are read by the AWS SDK from the environment.
# In production, prefer an IAM role attached to the compute (ECS task role,
# EC2 instance profile) instead of static keys — no key rotation needed.

AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_DEFAULT_REGION=us-east-1

# ─── Optional — Email Notifications ──────────────────────────────────────────
# Omit to disable email delivery (notifications will be silently skipped).
# Resend API key — https://resend.com
RESEND_API_KEY=re_...
# From address shown on notification emails (must be verified in Resend)
NOTIFICATION_FROM_EMAIL=notifications@yourdomain.com
# Base URL used to build deep-links in email bodies
NOTIFICATION_APP_URL=https://app.yourdomain.com

# ─── Cron security (required in production) ──────────────────────────────────
# Vercel cron routes are called with this secret in the Authorization header.
# REQUIRED in production — the app will refuse to start without it.
# Generate with: openssl rand -hex 32
CRON_SECRET=

# ─── Optional — SLA thresholds ───────────────────────────────────────────────
# Override enterprise policy defaults (hours)
SLA_REVIEW_WARN_HOURS=48
SLA_REVIEW_ALERT_HOURS=72

# ─── Optional — Redis ────────────────────────────────────────────────────────
# Connection URL for distributed rate limiting (recommended in multi-instance deployments).
# Without this the app falls back to in-process rate limiting (fine for single-instance dev).
# Docker Compose: redis://localhost:6379
# REDIS_URL=redis://localhost:6379

# ─── Optional — Database pool sizing (ADR-017) ───────────────────────────────
# Long-running Node server (Docker/EC2): 20–40 is typical
# Serverless (Vercel Functions — each invocation has its own pool): 5–10
# DB_POOL_MAX=20
# DB_IDLE_TIMEOUT_SEC=30
# DB_CONNECT_TIMEOUT_SEC=10

# ─── Encryption of secrets at rest (required in production, ADR-018) ─────────
# AES-256 key used to encrypt webhook HMAC signing secrets in the database.
# REQUIRED when NODE_ENV=production — the app will refuse to start without it.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# SECRETS_ENCRYPTION_KEY=

# ─── Optional — Logging ──────────────────────────────────────────────────────
# Minimum log level emitted by src/lib/logger.ts (default: "info")
# debug | info | warn | error
# LOG_LEVEL=info

# ─── Optional — AI model overrides ──────────────────────────────────────────
# Override the Claude model used for each task tier without code changes.
# Useful for responding to model deprecations or testing newer models.
# Defaults are the production-validated versions hardcoded in src/lib/ai/config.ts.
# AI_MODEL_SONNET=claude-sonnet-4-20250514
# AI_MODEL_HAIKU=claude-haiku-4-5-20251001

# ─── Optional — Bedrock circuit breaker (ADR-023) ───────────────────────────
# In-memory per-model circuit breaker that sheds load during sustained
# Bedrock degradation. Defaults are conservative and suitable for production.
# Set these explicitly only if you need tighter/looser behavior per tenant.
#
# Number of in-window failures before the breaker trips (default: 5)
# AI_BREAKER_THRESHOLD=5
# Sliding-window length for failure counting, in ms (default: 30000 = 30s)
# AI_BREAKER_WINDOW_MS=30000
# Initial cooldown after trip, in ms. Doubles on each failed probe up to the
# max. (default: 60000 = 60s)
# AI_BREAKER_COOLDOWN_MS=60000
# Ceiling for the exponentially-backed-off cooldown, in ms (default: 300000 = 5m)
# AI_BREAKER_MAX_COOLDOWN_MS=300000

# ─── Optional — Cron batch-runner (ADR-024) ──────────────────────────────────
# Wall-clock budget for a single cron invocation, in ms. The batch runner stops
# starting new items once this is crossed and reports the run as
# `budget_exhausted=true`. Default 50000 leaves ~10s headroom under Vercel's 60s
# function cap; raise if your runtime has a longer cap, lower if a bespoke
# per-cron schedule calls for it.
# CRON_BUDGET_MS=50000

# ─── Optional — Evidence-package PDF renderer (ADR-015 / OQ-009) ─────────────
# When the app runs on a serverless platform (Vercel, AWS Lambda), the
# /api/blueprints/[id]/evidence-package/pdf route uses @sparticuz/chromium-min,
# which loads a slim Chromium binary from a hosted URL on cold start to stay
# under the 250 MB function size limit.
#
# Recommended hosting: a public S3 object pointing to a chromium-min release
# tarball. See https://github.com/Sparticuz/chromium for the publishing pattern.
#
# REQUIRED in production / serverless. Local dev falls back to Playwright's
# bundled Chromium and ignores this var.
# CHROMIUM_REMOTE_EXECUTABLE_URL=https://your-bucket.s3.amazonaws.com/chromium-pack.tar

# ─── Demo mode ───────────────────────────────────────────────────────────────
# Set to "true" to show demo account quick-fill buttons on the login page.
# Omit or set to "false" in production (P1-56).
# NEXT_PUBLIC_DEMO_MODE=true
