# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/intellios

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET=

# Notifications (optional — omit to disable email delivery)
# Resend API key — https://resend.com
RESEND_API_KEY=re_...
# From address shown on notification emails
NOTIFICATION_FROM_EMAIL=notifications@yourdomain.com
# Base URL used to build deep-links in email bodies
NOTIFICATION_APP_URL=https://app.yourdomain.com

# SLA thresholds (hours) — override enterprise policy defaults
# Default: 48h warn, 72h breach
SLA_REVIEW_WARN_HOURS=48
SLA_REVIEW_ALERT_HOURS=72
