{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "BedrockAgentsTrustPolicy",
      "Effect": "Allow",
      "Principal": { "Service": "bedrock.amazonaws.com" },
      "Action": "sts:AssumeRole",
      "Condition": {
        "StringEquals": { "aws:SourceAccount": "<ACCOUNT_ID>" },
        "ArnLike": { "aws:SourceArn": "arn:aws:bedrock:us-east-1:<ACCOUNT_ID>:agent/*" }
      }
    }
  ]
}
