# Claude Code local settings — contains API keys and secrets
.claude/settings.local.json
.claude/worktrees/

# Next.js build output (also excluded in src/.gitignore)
.next/
node_modules/

# Scratch / working documents — not part of the codebase
landing-page-audit-*.md
production-readiness-review.html
claude-code-prompt*.md

# Sample artifacts — PDFs are binary; use Git LFS or external storage instead
samples/*.pdf

# Temp / lock files
.~lock.*

# Demo-video pipeline outputs — binary artifacts generated by Session 172 run
# (narration audio, intermediate clips, final MP4). Source files under
# scripts/demo-video/ ARE tracked; only output/ contents are ignored.
scripts/demo-video/output/*
!scripts/demo-video/output/.gitkeep
